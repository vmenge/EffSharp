<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>EffSharp.Core</PackageId>
    <Version>0.0.2</Version>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/vmenge/EffSharp</PackageProjectUrl>
    <RepositoryUrl>https://github.com/vmenge/EffSharp</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Prelude.fs" />
    <Compile Include="Report.fs" />
    <Compile Include="EffTypes.fs" />
    <Compile Include="EffRuntime.fs" />
    <Compile Include="EffNodes.fs" />
    <Compile Include="EffApi.fs" />
    <Compile Include="CE.fs" />
    <Compile Include="ReportCE.fs" />
  </ItemGroup>

  <ItemGroup Condition="$(DefineConstants.Contains('FABLE_COMPILER'))">
    <PackageReference Include="Fable.Core" />
    <PackageReference Include="Fable.Promise" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FSharp.Core" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="*.fs" PackagePath="fable/" />
  </ItemGroup>

</Project>
