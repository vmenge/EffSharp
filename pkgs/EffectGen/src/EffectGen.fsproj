<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="ProjectInputs.fs" />
    <Compile Include="Model.fs" />
    <Compile Include="Naming.fs" />
    <Compile Include="Classification.fs" />
    <Compile Include="FcsParsing.fs" />
    <Compile Include="Discovery.fs" />
    <Compile Include="Validation.fs" />
    <Compile Include="Emission.fs" />
    <Compile Include="Generation.fs" />
    <Compile Include="EffectAttribute.fs" />
    <Compile Include="GeneratorTask.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FSharp.Core" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="Microsoft.Build.Framework">
      <HintPath>$(MSBuildBinPath)/Microsoft.Build.Framework.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Microsoft.Build.Utilities.Core">
      <HintPath>$(MSBuildBinPath)/Microsoft.Build.Utilities.Core.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="FSharp.Compiler.Service">
      <HintPath>$(MSBuildBinPath)/FSharp/FSharp.Compiler.Service.dll</HintPath>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <None Include="..\buildTransitive\EffectGen.props" Pack="true" PackagePath="buildTransitive\EffectGen.props" Visible="false" />
    <None Include="..\buildTransitive\EffectGen.targets" Pack="true" PackagePath="buildTransitive\EffectGen.targets" Visible="false" />
    <None Include="bin\$(Configuration)\$(TargetFramework)\EffectGen.dll" Pack="true" PackagePath="buildTransitive\$(TargetFramework)\EffectGen.dll" Visible="false" />
    <None Include="bin\$(Configuration)\$(TargetFramework)\EffectGen.deps.json" Pack="true" PackagePath="buildTransitive\$(TargetFramework)\EffectGen.deps.json" Visible="false" />
    <None Include="bin\$(Configuration)\$(TargetFramework)\FSharp.Core.dll" Pack="true" PackagePath="buildTransitive\$(TargetFramework)\FSharp.Core.dll" Visible="false" />
    <None Include="bin\$(Configuration)\$(TargetFramework)\FSharp.Compiler.Service.dll" Pack="true" PackagePath="buildTransitive\$(TargetFramework)\FSharp.Compiler.Service.dll" Visible="false" />
  </ItemGroup>

</Project>
