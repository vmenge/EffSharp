<Project>
  <PropertyGroup>
    <EffectGenTaskAssemblyPath Condition="'$(EffectGenTaskAssemblyPath)' == '' and Exists('$(MSBuildThisFileDirectory)..\src\bin\$(Configuration)\$(TargetFramework)\EffectGen.dll')">$(MSBuildThisFileDirectory)..\src\bin\$(Configuration)\$(TargetFramework)\EffectGen.dll</EffectGenTaskAssemblyPath>
    <EffectGenTaskAssemblyPath Condition="'$(EffectGenTaskAssemblyPath)' == ''">$(MSBuildThisFileDirectory)$(TargetFramework)\EffectGen.dll</EffectGenTaskAssemblyPath>
  </PropertyGroup>

  <UsingTask
    TaskName="EffFs.EffectGen.GenerateEffectFilesTask"
    AssemblyFile="$(EffectGenTaskAssemblyPath)"
    Runtime="NET"
    Architecture="*"
    TaskFactory="TaskHostFactory"
    Condition="'$(EffectGenEnabled)' == 'true' and Exists('$(EffectGenTaskAssemblyPath)') and '$(MSBuildRuntimeType)' == 'Full'" />

  <UsingTask
    TaskName="EffFs.EffectGen.GenerateEffectFilesTask"
    AssemblyFile="$(EffectGenTaskAssemblyPath)"
    Runtime="NET"
    Architecture="*"
    Condition="'$(EffectGenEnabled)' == 'true' and Exists('$(EffectGenTaskAssemblyPath)') and '$(MSBuildRuntimeType)' == 'Core'" />

  <Target
    Name="EffectGenGenerateSources"
    BeforeTargets="FSharpSourceCodeCompileOrder"
    Condition="'$(EffectGenEnabled)' == 'true' and '$(Language)' == 'F#' and Exists('$(EffectGenTaskAssemblyPath)')">
    <ItemGroup>
      <_EffectGenDefine Include="$(DefineConstants)" Condition="'$(DefineConstants)' != ''" />
      <_EffectGenParseCommandLineArg Include="--targetprofile:$(TargetProfile)" Condition="'$(TargetProfile)' != ''" />
      <_EffectGenParseCommandLineArg Include="--langversion:$(LangVersion)" Condition="'$(LangVersion)' != ''" />
      <_EffectGenParseCommandLineArg Include="@(_EffectGenDefine->'--define:%(Identity)')" />
      <_EffectGenParseCommandLineArg Include="@(DisabledLanguageFeatures->'--disable-language-feature:%(Identity)')" />
    </ItemGroup>

    <GenerateEffectFilesTask
      ProjectDirectory="$(MSBuildProjectDirectory)"
      IntermediateOutputPath="$(IntermediateOutputPath)"
      CompileItems="@(Compile)"
      ParseCommandLineArgs="@(_EffectGenParseCommandLineArg)"
      OtherFlags="$(OtherFlags)">
      <Output TaskParameter="GeneratedFiles" ItemName="FileWrites" />
      <Output TaskParameter="OrderedCompileItems" ItemName="_EffectGenOrderedCompile" />
    </GenerateEffectFilesTask>

    <ItemGroup>
      <Compile Remove="@(Compile)" />
      <Compile Include="@(_EffectGenOrderedCompile)" />
    </ItemGroup>
  </Target>
</Project>
