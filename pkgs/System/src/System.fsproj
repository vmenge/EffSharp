<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>EffSharp.System</AssemblyName>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>EffSharp.System</PackageId>
    <Version>0.0.2</Version>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/vmenge/EffSharp</PackageProjectUrl>
    <RepositoryUrl>https://github.com/vmenge/EffSharp</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="AssemblyInfo.fs" />
    <Compile Include="Path.fs" />
    <Compile Include="Net.fs" />
    <Compile Include="Command.fs" />
    <Compile Include="Cmd.fs" />
    <Compile Include="Env.fs" />
    <Compile Include="Fs.fs" />
    <Compile Include="Stdio.fs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Gen\src\Gen.fsproj" PrivateAssets="all" />
    <ProjectReference Include="..\..\Std\src\Std.fsproj" />
  </ItemGroup>

</Project>
